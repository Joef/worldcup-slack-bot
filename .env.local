# Slack stuff
SLACK_TOKEN=XXXXXXXXXXXXXXXX
SLACK_CHANNEL=#worldcup
SLACK_BOT_NAME=WorldCup Bot
SLACK_BOT_AVATAR=https://i.imgur.com/Pd0cpqE.png

# Proxy (set USE_PROXY=true to enable)
USE_PROXY=false
PROXY=http://myproxy:3128
# If proxy authentication is needed, set to "user:password"
PROXY_USERPWD=

# Language for updates (fr-FR or en-GB)
LOCALE=en-GB
